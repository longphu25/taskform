{
  "files": {
    "includes": [
      "src/**/*.{ts,tsx,js,jsx}",
      "vite.config.ts",
      "commitlint.config.ts",
      "eslint.config.js"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all",
      "bracketSpacing": true,
      "jsxQuoteStyle": "double",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "enabled": false
  },
  "assist": {
    "enabled": false
  }
}
